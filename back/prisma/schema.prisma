  dt_criacao      DateTime @default(now()) @db.Timestamp(6)
  dt_atualizacao  DateTime @default(now()) @db.Timestamp(6)
  cd_funcionario  Int?
}

model anamnese_assinaturas {
  cd_assinatura              Int      @id @default(autoincrement())
