  engineType    = "client"
}

datasource db {
  provider = "postgresql"
}

model agendas {
  cd_agenda      Int             @id @default(autoincrement())
  ds_agenda      String?         @db.VarChar(64)
  ds_logradouro  String?         @db.VarChar(64)
  ds_numero      String?         @db.VarChar(8)
  ds_complemento String?         @db.VarChar(32)
  ds_telefone    String?         @db.VarChar(16)
  ds_celular     String?         @db.VarChar(16)
  ds_contato     String?         @db.VarChar(16)
  ds_email       String?         @db.VarChar(64)
  cd_grupo       Int?
  ds_observacao  String?         @db.VarChar(64)
  ds_cep         String?         @db.VarChar(8)
  ds_bairro      String?         @db.VarChar(64)
  ds_cidade      String?         @db.VarChar(64)
  ds_estado      String?         @db.VarChar(2)
  ds_telefone01  String?         @db.VarChar(16)
  ds_telefone02  String?         @db.VarChar(16)
  ds_telefone03  String?         @db.VarChar(16)
  cd_funcionario Int?
  ds_skype       String?         @db.VarChar(64)
  ds_msn         String?         @db.VarChar(64)
  ds_ibge        String?         @db.VarChar(8)
  agendas_grupos agendas_grupos? @relation(fields: [cd_grupo], references: [cd_grupo], onDelete: NoAction, onUpdate: NoAction, map: "$1")
}

model agendas_grupos {
  cd_grupo       Int       @id @default(autoincrement())
  ds_grupo       String?   @db.VarChar(64)
  cd_funcionario Int?
  agendas        agendas[]
}

model anamnese_arquivos {
  cd_arquivo      Int      @id @default(autoincrement())
