}

model arquivosrm {
  codimagem    Int     @id @default(autoincrement())
  codfilme     Int?
  codpatologia Int?
  descricao    String? @db.VarChar(255)
  publicar     String? @default("S") @db.Char(1)
  nomeimagem   String? @db.VarChar(8)
  imprimir     String? @default("N") @db.Char(1)

  @@index([codfilme], map: "codfilme_arquivosrm_key")
  @@index([nomeimagem], map: "nomeimagem_arquivosrm_key")
}

